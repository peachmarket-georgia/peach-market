{
  "name": "peachmarket",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "docker compose -f docker/docker-compose.local.yml up -d && turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css,yaml,yml}\"",
    "check-types": "turbo run check-types",
    "prepare": "husky",
    "swagger-to-type": "./scripts/swagger-to-type.sh",
    "install:web": "pnpm --filter web install",
    "install:api": "pnpm --filter api install",
    "install:all": "pnpm install",
    "test": "pnpm --filter api test && pnpm --filter web test",
    "test:api": "pnpm --filter api test",
    "test:api:cov": "pnpm --filter api test:cov",
    "test:api:e2e": "pnpm --filter api test:e2e",
    "test:web": "pnpm --filter web test"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.7.4",
    "turbo": "^2.8.3",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.2",
      "@types/react-dom": "19.2.2"
    }
  }
}
