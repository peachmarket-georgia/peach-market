# API 서버 URL (클라이언트용 - 더 이상 사용 안함, 프록시 경유)
NEXT_PUBLIC_API_URL=http://localhost:3003

# API 서버 URL (서버 전용 - 프록시 및 서버 컴포넌트용)
API_URL=http://localhost:3003
API_SECRET_KEY=your-api-secret-key-same-as-nestjs

# Google Maps (Geocoding API - 위치 자동완성용)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Monitoring
NEXT_PUBLIC_GA_ID=
