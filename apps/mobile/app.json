{
  "expo": {
    "name": "Peach Market",
    "slug": "peachmarket",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "peachmarket",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FF6B35"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.peachmarket.app",
      "infoPlist": {
        "NSCameraUsageDescription": "사진 촬영 및 상품 이미지 업로드에 사용됩니다.",
        "NSPhotoLibraryUsageDescription": "상품 이미지 선택에 사용됩니다.",
        "NSLocationWhenInUseUsageDescription": "내 위치 기반 거래를 위해 사용됩니다.",
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true,
          "NSAllowsLocalNetworking": true
        },
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.peachmarket.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#FF6B35"
      },
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION"
      ],
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "사진 촬영 및 상품 이미지 업로드에 사용됩니다."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "내 위치 기반 거래를 위해 사용됩니다."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "25ff0aff-c0a8-49e4-bedb-8db4c14f3901"
      },
      "router": {}
    }
  }
}
