# ==================================
# Environment
# ==================================
NODE_ENV=development
PORT=3003

# ==================================
# PostgreSQL (Local - Docker Compose)
# ==================================
POSTGRES_DB=peachmarket
POSTGRES_USER=peachmarket
POSTGRES_PASSWORD=peachmarket123
DATABASE_URL=postgresql://peachmarket:peachmarket123@localhost:5433/peachmarket

# Railway PostgreSQL (Production)
# DATABASE_URL=postgresql://user:password@containers-us-west-xxx.railway.app:5432/railway

# ==================================
# JWT Configuration
# ==================================
JWT_SECRET=your-jwt-secret-key-min-32-chars-change-this-in-production

# ==================================
# Google OAuth 2.0
# ==================================
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3003/api/auth/google/callback
# Production: https://api.peachmarket.com/api/auth/google/callback

# ==================================
# Email Service (Resend)
# ==================================
RESEND_API_KEY=your-resend-api-key

# ==================================
# Frontend URL (CORS)
# ==================================
FRONTEND_URL=http://localhost:3000
# Production: https://peachmarket.vercel.app

# ==================================
# Additional CORS Origins (comma-separated, optional)
# ==================================
# ALLOWED_ORIGINS=https://admin.peachmarket.com,https://staging.peachmarket.com

# ==================================
# Supabase Storage
# ==================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ==================================
# API Security (Proxy Authentication)
# ==================================
API_SECRET_KEY=your-api-secret-key-generate-with-openssl-rand-base64-32
