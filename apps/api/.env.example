# ===========================================
# 피치마켓 API 환경 변수
# ===========================================
#
# 📌 이 파일을 .env로 복사해서 사용하세요:
#    $ cp .env.example .env
#
# ⚠️ .env 파일은 절대로 git에 커밋하면 안 됩니다!
#    (.gitignore에 이미 추가되어 있음)
#
# ===========================================

# 포트 설정
PORT=4000

# 데이터베이스 연결 URL
# 형식: postgresql://[사용자]:[비밀번호]@[호스트]:[포트]/[DB명]
DATABASE_URL="postgresql://peachmarket:peachmarket123@localhost:5432/peachmarket"

# JWT 인증 설정
# 🔐 프로덕션에서는 반드시 강력한 랜덤 문자열로 변경하세요!
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"
