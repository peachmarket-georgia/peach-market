generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String   @id @default(uuid())
  email           String   @unique
  password        String? // bcrypt 해시 (OAuth 사용자는 NULL)
  nickname        String   @unique // 닉네임 중복 불가
  avatarUrl       String?
  location        String // 활동 지역 (둘루스, 애틀랜타 등)
  mannerScore     Float    @default(0.0) // 매너 점수 (0.0 ~ 5.0)
  isEmailVerified Boolean  @default(false) // 이메일 인증 여부
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // 관계
  products              Product[]            @relation("SellerProducts")
  reviewsGiven          Review[]             @relation("ReviewsGiven")
  reviewsReceived       Review[]             @relation("ReviewsReceived")
  buyerChatRooms        ChatRoom[]           @relation("BuyerChatRooms")
  sellerChatRooms       ChatRoom[]           @relation("SellerChatRooms")
  buyerReservations     Reservation[]        @relation("BuyerReservations")
  sellerReservations    Reservation[]        @relation("SellerReservations")
  messages              Message[]
  favorites             Favorite[]
  sessions              Session[] // 여러 디바이스 로그인 지원
  accounts              Account[] // OAuth 계정 연결 (Google, Facebook 등)
  emailVerifications    EmailVerification[] // 이메일 인증 토큰
  passwordResetRequests PasswordReset[] // 비밀번호 재설정 요청

  @@map("users")
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  refreshToken String // Refresh Token 해시
  deviceInfo   String? // User-Agent, 디바이스 정보
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model Account {
  id                String   @id @default(uuid())
  userId            String
  provider          String // "google", "facebook", "apple" 등
  providerAccountId String // OAuth 제공자의 고유 ID
  refreshToken      String? // OAuth Refresh Token
  accessToken       String? // OAuth Access Token
  expiresAt         Int? // Token 만료 시간 (Unix timestamp)
  tokenType         String?
  scope             String?
  idToken           String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // 관계
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 같은 제공자에서 중복 계정 연결 방지
  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

// 이메일 인증 토큰
model EmailVerification {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique // 인증 토큰
  expiresAt DateTime // 만료 시간 (24시간)
  createdAt DateTime @default(now())

  // 관계
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt]) // 만료된 토큰 정리용
  @@map("email_verifications")
}

// 비밀번호 재설정 요청
model PasswordReset {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique // 재설정 토큰
  expiresAt DateTime // 만료 시간 (1시간)
  used      Boolean  @default(false) // 사용 여부
  createdAt DateTime @default(now())

  // 관계
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt]) // 만료된 토큰 정리용
  @@map("password_resets")
}

// 상품 상태
enum ProductStatus {
  SELLING  // 판매 중 (🟢)
  RESERVED // 예약 중 (🟡)
  CONFIRMED // 판매 확정 (🟣)
  ENDED    // 판매 종료 (⚫)
}

// 예약/거래 상태 (구매자-판매자 간 진행 상태)
enum ReservationStatus {
  RESERVED  // 예약중
  COMPLETED // 양측 거래 완료 확인
  CANCELED  // 취소
}

// 결제 수단
enum PaymentMethod {
  CASH // 현금
  ZELLE // Zelle
  VENMO // Venmo
}

model Product {
  id          String        @id @default(uuid())
  sellerId    String
  title       String
  description String
  price       Int // USD 달러 단위
  category    String // 카테고리 (디지털기기, 생활가전 등)
  status      ProductStatus @default(SELLING)
  images         String[] // 이미지 URL 배열 (최대 10장)
  location       String // 거래 희망 지역
  paymentMethods PaymentMethod[] @default([]) // 선호 결제 수단
  viewCount   Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // 관계
  seller    User       @relation("SellerProducts", fields: [sellerId], references: [id], onDelete: Cascade)
  reviews   Review[]
  chatRooms ChatRoom[]
  favorites Favorite[]
  reservations Reservation[]

  @@index([sellerId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("products")
}

// 예약/거래 진행 기록 (대면 거래 후 양측 확인)
model Reservation {
  id                String            @id @default(uuid())
  productId         String
  buyerId           String
  sellerId          String
  status            ReservationStatus @default(RESERVED)
  buyerConfirmedAt  DateTime? // 구매자 "구매완료" 클릭 시각
  sellerConfirmedAt DateTime? // 판매자 "판매완료" 클릭 시각
  completedAt       DateTime? // 양측 확인 완료 시각
  canceledAt        DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  // 관계
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  buyer   User    @relation("BuyerReservations", fields: [buyerId], references: [id], onDelete: Cascade)
  seller  User    @relation("SellerReservations", fields: [sellerId], references: [id], onDelete: Cascade)

  // 같은 상품에 대해 같은 구매자는 중복 예약 방지
  @@unique([productId, buyerId])
  @@index([productId])
  @@index([buyerId])
  @@index([sellerId])
  @@index([status])
  @@map("reservations")
}

// 리뷰/매너 평가
model Review {
  id         String   @id @default(uuid())
  reviewerId String // 평가자
  revieweeId String // 평가 대상자
  productId  String // 거래 상품
  score      Int // 1 ~ 5점
  comment    String? // 선택적 코멘트
  createdAt  DateTime @default(now())

  // 관계
  reviewer User    @relation("ReviewsGiven", fields: [reviewerId], references: [id], onDelete: Cascade)
  reviewee User    @relation("ReviewsReceived", fields: [revieweeId], references: [id], onDelete: Cascade)
  product  Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  // 한 거래당 한 번만 평가 가능
  @@unique([reviewerId, productId])
  @@index([revieweeId])
  @@map("reviews")
}

// 채팅방
model ChatRoom {
  id          String   @id @default(uuid())
  productId   String?  // nullable — 상품 삭제 후에도 채팅 기록 보존
  buyerId     String
  sellerId    String
  lastMessage String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // 관계
  product  Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)
  buyer    User      @relation("BuyerChatRooms", fields: [buyerId], references: [id], onDelete: Cascade)
  seller   User      @relation("SellerChatRooms", fields: [sellerId], references: [id], onDelete: Cascade)
  messages Message[]

  // 같은 상품에 대해 구매자-판매자 채팅방은 하나만 (productId null 시 PostgreSQL에서 NULL != NULL이므로 중복 허용)
  @@unique([productId, buyerId])
  @@index([buyerId])
  @@index([sellerId])
  @@map("chat_rooms")
}

// 채팅 메시지
model Message {
  id         String   @id @default(uuid())
  chatRoomId String
  senderId   String
  content    String
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())

  // 관계
  chatRoom ChatRoom @relation(fields: [chatRoomId], references: [id], onDelete: Cascade)
  sender   User     @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([chatRoomId])
  @@index([createdAt])
  @@map("messages")
}

// 관심 상품
model Favorite {
  id        String   @id @default(uuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  // 관계
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  // 중복 관심 등록 방지
  @@unique([userId, productId])
  @@index([userId])
  @@map("favorites")
}
